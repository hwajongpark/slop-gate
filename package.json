{
  "name": "slop-gate",
  "version": "0.2.0",
  "description": "Catch AI writing-tells before they ship. Zero-dependency CLI with editable per-language packs: the em-dash, ~40 English filler tells, and Korean translationese (번역투). Runs locally or in CI.",
  "bin": {
    "slop-gate": "bin/slop-gate.js"
  },
  "type": "commonjs",
  "files": [
    "bin",
    "rules"
  ],
  "scripts": {
    "demo": "node bin/slop-gate.js examples/sample.md || true",
    "test": "node test/run.js"
  },
  "keywords": [
    "ai",
    "llm",
    "ai-detection",
    "slop",
    "writing",
    "prose",
    "linter",
    "ci",
    "em-dash",
    "content",
    "editorial",
    "korean",
    "translationese",
    "multilingual",
    "i18n"
  ],
  "author": "Hwajong (Howard) Park",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hwajongpark/slop-gate.git"
  },
  "engines": {
    "node": ">=18"
  }
}
