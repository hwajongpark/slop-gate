{
  "name": "slop-gate",
  "version": "0.4.3",
  "description": "Catch AI writing-tells before they ship. Zero-dependency CLI with editable, opt-in language packs for Korean, Russian, Vietnamese, Chinese, and Filipino, plus ~40 English tells and the em-dash. Runs locally or in CI.",
  "bin": {
    "slop-gate": "bin/slop-gate.js"
  },
  "type": "commonjs",
  "files": [
    "bin",
    "rules"
  ],
  "scripts": {
    "demo": "node bin/slop-gate.js examples/sample.md || true",
    "test": "node test/run.js"
  },
  "keywords": [
    "ai",
    "llm",
    "ai-detection",
    "ai-slop",
    "slop",
    "ai-writing",
    "ai-content",
    "writing-tells",
    "anti-slop",
    "writing",
    "prose",
    "linter",
    "ci",
    "em-dash",
    "content",
    "editorial",
    "korean",
    "translationese",
    "multilingual",
    "i18n",
    "russian",
    "vietnamese",
    "chinese",
    "filipino",
    "tagalog"
  ],
  "author": "Hwajong (Howard) Park",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hwajongpark/slop-gate.git"
  },
  "engines": {
    "node": ">=18"
  }
}
