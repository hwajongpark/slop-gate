{
  "id": "vocabulary",
  "description": "Words and phrases that appear far more often in AI-drafted text than in writing a person produces unprompted.",
  "flags": "i",
  "rules": [
    { "id": "delve", "match": "\\bdelve\\b", "hint": "Use 'look at', 'go into', or 'cover'." },
    { "id": "leverage", "match": "\\bleverage\\b", "hint": "Use 'use' or 'take advantage of'." },
    { "id": "navigate-complexities", "match": "\\bnavigat(e|ing) the complexit(y|ies)\\b", "hint": "Name the actual task: 'handle', 'work through'." },
    { "id": "fast-paced-world", "match": "\\bin today['’]?s (fast-paced|digital|modern|ever-changing) (world|age|landscape|era)\\b", "hint": "Delete it. Start with the subject." },
    { "id": "comprehensive-guide", "match": "\\b(comprehensive|complete|ultimate|definitive) guide\\b", "hint": "Drop it. A good guide proves itself." },
    { "id": "robust", "match": "\\brobust\\b", "hint": "Name the specific strength." },
    { "id": "seamless", "match": "\\bseamless(ly)?\\b", "hint": "Describe what actually works without friction." },
    { "id": "transformative", "match": "\\btransformative\\b", "hint": "Show the change concretely." },
    { "id": "cutting-edge", "match": "\\bcutting[- ]edge\\b", "hint": "Say what is actually new." },
    { "id": "elevate", "match": "\\belevate(s|d)?\\b", "hint": "Describe the gain." },
    { "id": "empower", "match": "\\bempower(s|ed|ing)?\\b", "hint": "Say what the reader can now do." },
    { "id": "unlock", "match": "\\bunlock(s|ed|ing)?\\b", "hint": "Say what becomes available." },
    { "id": "harness", "match": "\\bharness(es|ed|ing)?\\b", "hint": "Use 'use'." },
    { "id": "streamline", "match": "\\bstreamlin(e|es|ed|ing)\\b", "hint": "Say what gets faster or simpler." },
    { "id": "proactive", "match": "\\bproactive(ly)?\\b", "hint": "Say the specific action taken in advance." },
    { "id": "worth-noting", "match": "\\bit['’]?s (worth|important) (noting|to note)\\b", "hint": "Delete it. Lead with the fact." },
    { "id": "feel-free", "match": "\\b(feel free to|don['’]?t hesitate to)\\b", "hint": "State the action directly." },
    { "id": "end-of-the-day", "match": "\\bat the end of the day\\b", "hint": "Cut it. State the point." },
    { "id": "in-conclusion", "match": "\\bin conclusion\\b", "hint": "Cut it. State the conclusion." },
    { "id": "dive-in", "match": "\\blet['’]?s dive (in|into)\\b", "hint": "Cut it. Start the section." },
    { "id": "tapestry", "match": "\\b(rich )?tapestry\\b", "hint": "A classic AI tell. Be literal about what is there." },
    { "id": "testament", "match": "\\b(a )?testament to\\b", "hint": "Say what it proves, plainly." },
    { "id": "in-the-realm", "match": "\\bin the realm of\\b", "hint": "Use 'in', or name the field." },
    { "id": "realm", "match": "\\brealm\\b", "hint": "Use 'area' or 'field'." },
    { "id": "when-it-comes-to", "match": "\\bwhen it comes to\\b", "hint": "Often deletable. Name the subject." },
    { "id": "game-changer", "match": "\\bgame[- ]chang(er|ing)\\b", "hint": "Say what specifically changes." },
    { "id": "top-notch", "match": "\\btop[- ]notch\\b", "hint": "Say why it is good." },
    { "id": "bustling", "match": "\\bbustling\\b", "hint": "A travel-AI tell. Be specific." },
    { "id": "nestled", "match": "\\bnestled\\b", "hint": "A travel-AI tell. Say where, plainly." },
    { "id": "treasure-trove", "match": "\\btreasure trove\\b", "hint": "Say what is actually there." },
    { "id": "embark", "match": "\\bembark(ing)? on\\b", "hint": "Use 'start'." },
    { "id": "foster", "match": "\\bfoster(s|ed|ing)? a (sense|culture|environment|spirit)\\b", "hint": "Say what is built." },
    { "id": "meticulous", "match": "\\bmeticulous(ly)?\\b", "hint": "Show the care concretely." },
    { "id": "underscore", "match": "\\bunderscore(s|d)? the (importance|need|value|significance)\\b", "hint": "Say why it matters, plainly." },
    { "id": "moreover", "match": "\\bmoreover\\b", "hint": "Often deletable. Start a new sentence." },
    { "id": "furthermore", "match": "\\bfurthermore\\b", "hint": "Often deletable. Start a new sentence." },
    { "id": "crucial", "match": "\\bcrucial\\b", "hint": "Use 'important', or say why it matters." },
    { "id": "pivotal", "match": "\\bpivotal\\b", "hint": "Say what it determines." },
    { "id": "vibrant", "match": "\\bvibrant\\b", "hint": "Be specific about what you see." }
  ]
}
